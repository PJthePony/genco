# Genco iMessage Bridge Configuration
GENCO_API_URL=https://your-server.up.railway.app
BRIDGE_API_KEY=your-shared-secret-here
GENCO_USER_ID=your-supabase-user-id

# How often to check for new messages (milliseconds, default: 60000 = 1 min)
POLL_INTERVAL_MS=60000

# How far back to look for messages (minutes, default: 120 = 2 hours)
MESSAGE_LOOKBACK_MINUTES=120
